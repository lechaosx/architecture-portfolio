---
import Base from '../layouts/Base.astro';
import T from '../components/T.astro';
import { frontmatter as site } from '../content/singletons/site.md';
import { frontmatter as contact } from '../content/singletons/contact.md';
import { ui } from '../i18n';

const { email, phone } = contact;
const hours: { day_cs: string; day_en: string; hours: string }[] =
  contact.hours ?? [];
---

<Base
  title={{
    cs: `${ui.cs.contact} — ${site.name}`,
    en: `${ui.en.contact} — ${site.name}`,
  }}
>
  <section class="mx-auto max-w-6xl px-6 pt-12 pb-16 sm:pt-16 sm:pb-24">
    <T as="h1" k="contact" class="text-3xl font-medium sm:text-4xl" />

    <div class="mt-10 grid gap-10 md:mt-12 md:grid-cols-2 md:gap-16">
      <dl class="reveal space-y-8">
        <div>
          <T
            as="dt"
            k="email"
            class="text-sm tracking-widest text-neutral-600 uppercase"
          />
          <dd class="mt-1 text-lg">
            <a
              href={`mailto:${email}`}
              class="underline underline-offset-4 hover:decoration-dotted"
            >
              {email}
            </a>
          </dd>
        </div>

        {
          phone && (
            <div>
              <T
                as="dt"
                k="phone"
                class="text-sm tracking-widest text-neutral-600 uppercase"
              />
              <dd class="mt-1 text-lg">
                <a
                  href={`tel:${phone.replace(/\s+/g, '')}`}
                  class="underline underline-offset-4 hover:decoration-dotted"
                >
                  {phone}
                </a>
              </dd>
            </div>
          )
        }
      </dl>

      {
        hours.length > 0 && (
          <div class="reveal">
            <T
              as="h2"
              k="whenToReach"
              class="text-sm tracking-widest text-neutral-600 uppercase"
            />
            <ul class="mt-5 max-w-xs space-y-1.5">
              {hours.map((h) => (
                <li class="flex justify-between gap-8 border-b border-neutral-200 pb-1.5">
                  <T cs={h.day_cs} en={h.day_en} />
                  <span class="text-neutral-600">{h.hours}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </section>
</Base>

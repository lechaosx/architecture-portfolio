---
import Base from '../layouts/Base.astro';
import Carousel from '../components/Carousel.astro';
import Approaches from '../components/Approaches.astro';
import { Content, frontmatter as home } from '../content/singletons/home.md';
import { frontmatter as site } from '../content/singletons/site.md';
---

<Base title={`${site.name} — Architecture`}>
  <Carousel />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-10 md:grid-cols-2 md:items-start md:gap-16">
      <div class="reveal">
        <h2 class="text-sm tracking-widest uppercase">About</h2>
        <div class="prose prose-neutral mt-6 max-w-none">
          <Content />
        </div>
      </div>
      {
        home.portrait && (
          <img
            src={home.portrait}
            alt=""
            loading="lazy"
            class="reveal w-full bg-neutral-100 md:order-last"
          />
        )
      }
    </div>
  </section>

  <Approaches />
</Base>

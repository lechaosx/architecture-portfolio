---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import T from '../components/T.astro';
import { frontmatter as site } from '../content/singletons/site.md';
import { ui } from '../i18n';

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort(
    (a, b) =>
      b.data.year - a.data.year ||
      a.data.title_en.localeCompare(b.data.title_en),
  );
---

<Base
  title={{ cs: `${ui.cs.work} — ${site.name}`, en: `${ui.en.work} — ${site.name}` }}
>
  <section class="mx-auto max-w-6xl px-6 pt-12 pb-8 sm:pt-16">
    <T as="h1" k="work" class="text-3xl font-medium sm:text-4xl" />
  </section>

  <section
    class="mx-auto grid max-w-6xl grid-cols-1 gap-x-8 gap-y-12 px-6 pb-16 sm:grid-cols-2 sm:gap-x-12 sm:gap-y-20 sm:pb-24 lg:grid-cols-3 lg:gap-x-32"
  >
    {
      projects.map((p) => (
        <ProjectCard
          href={`/projects/${p.id}/`}
          slug={p.id}
          titleCs={p.data.title_cs}
          titleEn={p.data.title_en}
          year={p.data.year}
          locationCs={p.data.location_cs}
          locationEn={p.data.location_en}
          cover={p.data.cover}
        />
      ))
    }
  </section>
</Base>

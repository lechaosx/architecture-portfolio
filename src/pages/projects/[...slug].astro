---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Gallery from '../../components/Gallery.svelte';
import T from '../../components/T.astro';
import Prose from '../../components/Prose.astro';
import { frontmatter as site } from '../../content/singletons/site.md';
import { ui } from '../../i18n';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).filter((p) => !p.data.draft);
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const d = project.data;

const meta = (loc?: string) => [loc, d.year].filter(Boolean).join(' · ');
---

<Base
  title={{
    cs: `${d.title_cs} — ${site.name}`,
    en: `${d.title_en} — ${site.name}`,
  }}
>
  <article class="mx-auto max-w-4xl px-6 pt-16 pb-24">
    <a href="/work" class="text-sm text-neutral-500 hover:text-neutral-900">
      <T k="backToWork" />
    </a>

    <header class="mt-6 mb-8">
      <T
        as="h1"
        cs={d.title_cs}
        en={d.title_en}
        class="text-3xl font-medium sm:text-4xl"
      />
      <T
        as="p"
        cs={meta(d.location_cs)}
        en={meta(d.location_en)}
        class="mt-2 text-neutral-500"
      />
    </header>

    <img
      src={d.cover}
      alt={d.title_en}
      class="w-full bg-neutral-100 object-cover"
      transition:name={`cover-${project.id}`}
    />

    <Prose
      cs={d.body_cs}
      en={d.body_en}
      class="prose prose-neutral mt-10 max-w-none"
    />

    <Gallery images={d.gallery} client:visible />
  </article>
</Base>

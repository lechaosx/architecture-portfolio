---
import T from './T.astro';

interface Props {
  href: string;
  slug: string;
  titleCs: string;
  titleEn: string;
  year: number;
  locationCs?: string;
  locationEn?: string;
  cover: string;
}

const { href, slug, titleCs, titleEn, year, locationCs, locationEn, cover } =
  Astro.props;
---

<a href={href} class="reveal group relative block hover:z-10">
  <img
    src={cover}
    alt={titleEn}
    loading="lazy"
    decoding="async"
    class="aspect-square w-full bg-neutral-100 object-cover motion-safe:transition-transform motion-safe:duration-300 motion-safe:group-hover:scale-[1.03]"
    transition:name={`cover-${slug}`}
  />
  <div class="mt-3 flex items-baseline justify-between">
    <T as="h3" cs={titleCs} en={titleEn} class="text-base font-medium" />
    <span class="text-sm text-neutral-500">{year}</span>
  </div>
  {
    (locationCs || locationEn) && (
      <T
        as="p"
        cs={locationCs}
        en={locationEn}
        class="text-sm text-neutral-500"
      />
    )
  }
</a>

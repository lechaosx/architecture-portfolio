---
interface Props {
  href: string;
  slug: string;
  title: string;
  year: number;
  location?: string;
  cover: string;
}

const { href, slug, title, year, location, cover } = Astro.props;
---

<a href={href} class="reveal group block">
  <div class="aspect-[4/3] overflow-hidden bg-neutral-100">
    <img
      src={cover}
      alt={title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
      transition:name={`cover-${slug}`}
    />
  </div>
  <div class="mt-3 flex items-baseline justify-between">
    <h3 class="text-base font-medium">{title}</h3>
    <span class="text-sm text-neutral-500">{year}</span>
  </div>
  {location && <p class="text-sm text-neutral-500">{location}</p>}
</a>

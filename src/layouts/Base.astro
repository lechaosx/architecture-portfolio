---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/roboto';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { frontmatter as site } from '../content/singletons/site.md';

interface Bilingual {
  cs: string;
  en: string;
}

interface Props {
  title: Bilingual;
  description?: Bilingual;
}

const {
  title,
  description = { cs: site.description_cs, en: site.description_en },
} = Astro.props;
---

<!doctype html>
<html lang="en" data-lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Pick the language before first paint (query > saved > browser > en) so
         the correct-language content shows without a flash. -->
    <script is:inline>
      (function () {
        var url = new URLSearchParams(location.search).get('lang');
        var saved = null;
        try {
          saved = localStorage.getItem('lang');
        } catch (e) {}
        var nav = (navigator.language || '').toLowerCase();
        var lang = url || saved || (nav.indexOf('cs') === 0 ? 'cs' : 'en');
        if (lang !== 'cs' && lang !== 'en') lang = 'en';
        if (url === 'cs' || url === 'en') {
          try {
            localStorage.setItem('lang', url);
          } catch (e) {}
        }
        document.documentElement.dataset.lang = lang;
        document.documentElement.lang = lang;
      })();
    </script>

    <!-- Pick the theme before first paint (saved > system > light) so there's
         no light-to-dark flash. -->
    <script is:inline>
      (function () {
        var saved = null;
        try {
          saved = localStorage.getItem('theme');
        } catch (e) {}
        var theme =
          saved ||
          (window.matchMedia &&
          window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light');
        if (theme !== 'light' && theme !== 'dark') theme = 'light';
        document.documentElement.dataset.theme = theme;
      })();
    </script>

    <title>{title.en}</title>
    <meta name="page-title" data-cs={title.cs} data-en={title.en} />
    <meta
      name="description"
      content={description.en}
      data-cs={description.cs}
      data-en={description.en}
    />
    <meta property="og:title" content={title.en} />
    <meta property="og:description" content={description.en} />
    <meta property="og:type" content="website" />
    <!-- Smooth same-origin page swaps via the native View Transitions API. -->
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-white font-sans text-black antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Reveal elements as they enter the viewport, using the real scrollbar.
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>('.reveal:not(.is-visible)');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px' },
        );
        els.forEach((el) => io.observe(el));
      }

      // Sync the <title> and meta description to the active language.
      function applyLang() {
        const lang = document.documentElement.dataset.lang || 'en';
        const tm = document.querySelector('meta[name="page-title"]');
        if (tm)
          document.title =
            tm.getAttribute('data-' + lang) ||
            tm.getAttribute('data-en') ||
            document.title;
        const dm = document.querySelector('meta[name="description"]');
        const dv = dm?.getAttribute('data-' + lang);
        if (dm && dv) dm.setAttribute('content', dv);
      }

      // Wire the CZ | EN toggle: persist the choice and flip <html data-lang>.
      function wireToggle() {
        document.querySelectorAll<HTMLElement>('[data-lang-btn]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const lang = btn.dataset.langBtn || 'en';
            try {
              localStorage.setItem('lang', lang);
            } catch {}
            const el = document.documentElement;
            el.dataset.lang = lang;
            el.lang = lang;
            applyLang();
          });
        });
      }

      // Wire the theme toggle: flip <html data-theme> between light/dark and
      // persist the choice.
      function wireTheme() {
        document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const el = document.documentElement;
            const theme = el.dataset.theme === 'dark' ? 'light' : 'dark';
            try {
              localStorage.setItem('theme', theme);
            } catch {}
            el.dataset.theme = theme;
          });
        });
      }

      // Carry the chosen language and theme onto the incoming document so a View
      // Transition navigation doesn't reset them to the static defaults.
      document.addEventListener('astro:before-swap', (e) => {
        const el = document.documentElement;
        const incoming = (e as any).newDocument.documentElement as HTMLElement;
        incoming.dataset.lang = el.dataset.lang || 'en';
        incoming.lang = el.lang || 'en';
        incoming.dataset.theme = el.dataset.theme || 'light';
      });

      document.addEventListener('astro:page-load', () => {
        initReveal();
        applyLang();
        wireToggle();
        wireTheme();
      });
    </script>
  </body>
</html>
